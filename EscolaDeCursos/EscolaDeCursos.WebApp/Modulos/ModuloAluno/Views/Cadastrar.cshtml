@using EscolaDeCursos.WebApp.Modulos.ModuloAluno
@{
    Layout = "_Layout";
}

@model CadastrarAlunoViewModel

<a asp-action="Listar" class="botao-voltar">&larr; Voltar</a>

<div class="form-registro">
    <form asp-action="Cadastrar" method="post">

        <div asp-validation-summary="All" class="resumo-erros"></div>

        <div class="campo-grupo">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" />
            <span asp-validation-for="Nome" class="campo-erro"></span>
        </div>

        <div class="campo-grupo">
            <label asp-for="Cpf"></label>
            <input asp-for="Cpf" />
            <span asp-validation-for="Cpf" class="campo-erro"></span>
        </div>

        <div class="campo-grupo">
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="campo-erro"></span>
        </div>

        <div class="form-acoes">
            <button type="submit" class="botao-salvar">Cadastrar</button>
            <a asp-action="Listar" class="botao-cancelar">Cancelar</a>
        </div>

    </form>
</div>
