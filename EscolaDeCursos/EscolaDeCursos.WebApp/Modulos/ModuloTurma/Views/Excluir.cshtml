@using EscolaDeCursos.WebApp.Modulos.ModuloTurma
@{
    Layout = "_Layout";
}

@model ExcluirTurmaViewModel

<a asp-action="Listar" class="botao-voltar">&larr; Voltar</a>

<div class="card-confirmacao">

    <div class="alerta-perigo">
        Esta ação é permanente e não poderá ser desfeita.
    </div>

    <div class="card-cabecalho">
        <h3>@Model.Nome</h3>
        <span class="id-badge">@Model.CapacidadeAlunos vagas</span>
    </div>

    <p><strong>Curso:</strong> @Model.NomeCurso</p>
    <p><strong>Instrutor:</strong> @Model.NomeInstrutor</p>
    <p><strong>Início:</strong> @Model.DataInicio.ToString("dd/MM/yyyy")</p>
    <p><strong>Término:</strong> @Model.DataTermino.ToString("dd/MM/yyyy")</p>

    <form asp-action="Excluir" method="post" class="form-acoes">
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="botao-excluir">Confirmar Exclusão</button>
        <a asp-action="Listar" class="botao-cancelar">Cancelar</a>
    </form>

</div>
